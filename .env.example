# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=semantic_search
DB_USER=postgres
DB_PASSWORD=yourpassword

# Embedding model (from sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Search settings
TOP_K=10
BATCH_SIZE=64

# Ingestion limit — how many AG News articles to ingest (max ~120,000).
# Can also be overridden at the command line: INGEST_LIMIT=20000 bash run_all.sh
INGEST_LIMIT=5000

# Hugging Face API token (optional but recommended).
# Enables higher download rate limits when pulling datasets and models from the Hub. Without a token, downloads are unauthenticated and may be throttled on busy days. Here's how to get one:
#   1. Create a free account at https://huggingface.co
#   2. Go to https://huggingface.co/settings/tokens
#   3. Click "New token", choose "Read" scope, copy the value
#   4. Paste it below (remove the leading #)
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GPU / CUDA settings.
# The empty value below is intentional — it forces CPU inference and suppresses
# PyTorch's CUDA driver version warning when the installed NVIDIA driver is too
# old to be used (driver < 525). No action needed; leave it as-is unless you
# have a supported GPU driver, in which case remove this line entirely or
# comment it out to let PyTorch use the GPU automatically.
CUDA_VISIBLE_DEVICES=
