# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=semantic_search
DB_USER=postgres
DB_PASSWORD=yourpassword

# Embedding model (from sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Search settings
TOP_K=10
BATCH_SIZE=64

# Hugging Face API token (optional but recommended).
# Enables higher download rate limits when pulling datasets and models from the Hub.
# Without a token, downloads are unauthenticated and may be throttled on busy days.
#
# How to get one:
#   1. Create a free account at https://huggingface.co
#   2. Go to https://huggingface.co/settings/tokens
#   3. Click "New token", choose "Read" scope, copy the value
#   4. Paste it below (remove the leading #)

# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GPU / CUDA settings.
# Set to "" to force CPU inference and suppress PyTorch's CUDA driver version
# warning when the installed NVIDIA driver is too old to be used (driver < 525).
# Remove this line or set it to "0" once the driver has been updated.
CUDA_VISIBLE_DEVICES=
